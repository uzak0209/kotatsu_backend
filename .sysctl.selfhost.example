# Optional host sysctl tuning for the self-hosted Linux server.
# Copy to `.sysctl.selfhost` for local deploys, or store the same content in
# the GitHub Actions `HOME_SERVER_SYSCTL` secret for deploy-on-push.
#
# Adjust these values to match the host and workload. These defaults are a
# reasonable starting point for a small QUIC/UDP service.

net.core.rmem_default=262144
net.core.wmem_default=262144
net.core.rmem_max=7500000
net.core.wmem_max=7500000
net.ipv4.udp_rmem_min=16384
net.ipv4.udp_wmem_min=16384
